rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===== HELPER FUNCTIONS =====
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'deemaxsms@atomicmail.io' ||
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true)
      );
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    function incomingData() { return request.resource.data; }

    function isValidUserCreation() {
      return request.auth != null &&
             incomingData().email == request.auth.token.email &&
             incomingData().balance == 0 &&
             incomingData().cashback == 0 &&
             incomingData().useCashbackFirst == true &&
             (
               (!incomingData().keys().hasAny(['isAdmin', 'adminRole'])) || 
               (isAdmin())
             );
    }

    // ===== DEDICATED ADMINS COLLECTION =====
    match /admins/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && (
        request.auth.token.email == 'deemaxsms@atomicmail.io' || 
        isAdmin()
      );
      allow update, delete: if isAdmin();
    }

    // ===== USER DATA =====
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if isValidUserCreation();
      allow update: if request.auth != null && (isAdmin() || isOwner(userId));
      allow delete: if isAdmin();
    }

    // ===== NOTIFICATIONS (Fixes subscribeToUserNotifications error) =====
    match /notifications/{docId} {
      allow read, update: if request.auth != null && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isAdmin(); 
    }

    // ===== TRANSACTIONS & PAYMENTS (Fixes processPayment error) =====
   match /balance_transactions/{docId} {
      allow read: if request.auth != null && (isAdmin() || resource.data.userId == request.auth.uid);
      // Ensure the user can create the transaction record
      allow create: if request.auth != null && incomingData().userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Generic payments collection if used by your service
    match /payments/{docId} {
      allow read: if request.auth != null && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && incomingData().userId == request.auth.uid;
    }

    // ===== ORDERS (Fixes getOrdersByUser error) =====
    match /activations/{docId} {
      allow read, update: if request.auth != null && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && incomingData().userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /sms_orders/{docId} {
      allow read, update: if request.auth != null && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && incomingData().userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /orders/{docId} {
      allow read: if request.auth != null && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && incomingData().userId == request.auth.uid;
    }

    // ===== OTHER COLLECTIONS =====
    match /user_balances/{userId} {
      allow read: if request.auth != null && (isAdmin() || isOwner(userId));
      allow write: if request.auth != null && isOwner(userId); 
    }
    
  match /product_orders/{docId} {
      allow read: if request.auth != null && (isAdmin() || resource.data.userId == request.auth.uid);
      // FIXED: Allow users to create their own orders
      allow create: if request.auth != null && incomingData().userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /gift_orders/{docId} {
      allow read: if request.auth != null && (isAdmin() || resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }
    
    match /custom_gift_requests/{docId} {
      allow read: if request.auth != null && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && incomingData().userId == request.auth.uid && incomingData().status == 'pending';
      allow update, delete: if isAdmin();
    }

    // ===== PUBLIC READ / ADMIN WRITE =====
    match /product_listings/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /gift_categories/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /gifts/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /gift_availability/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /shipping_rates/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /shipping_size_fees/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /countries/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /services/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /restricted_countries/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /restricted_domains/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /settings/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /system_restrictions/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /in-app-msg/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /operators/{docId} { allow read: if true; allow write: if isAdmin(); }

    // ===== SYSTEM & ADMIN SETTINGS =====
    match /admin_settings/{docId} { allow read, write: if isAdmin(); }
    match /system_logs/{docId} { allow read, write: if isAdmin(); }
    match /system_settings/{docId} { allow read, write: if isAdmin(); }
    match /security_audits/{docId} { allow read, write: if isAdmin(); }

    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null && incomingData().userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ===== CATCH-ALL =====
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}