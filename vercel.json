{
  "build": {
    "env": {
      "NODE_VERSION": "20"
    }
  },
  "functions": {
    "api/*.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/tellabot",
      "destination": "/api/tellabot.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}